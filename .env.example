# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Database (PostgreSQL 15) ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=lucencare
DB_SSL=false

# ── Redis 7.x ─────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT RS256 ─────────────────────────────────────────────────────────────────
# Provide full PEM-encoded key strings (multi-line, use \n escapes in production secrets)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# ── S3-compatible Object Storage ──────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=lucencare-exports
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Default window: 60 req / 60 s per userId
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Auth endpoints: 10 req / 60 s per IP
AUTH_THROTTLE_TTL=60
AUTH_THROTTLE_LIMIT=10

# OTP endpoints: 3 req / 300 s per userId
OTP_THROTTLE_TTL=300
OTP_THROTTLE_LIMIT=3

# Export token endpoint: 5 req / 60 s per orgId
EXPORT_THROTTLE_TTL=60
EXPORT_THROTTLE_LIMIT=5

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300

# ── bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_CORS_ORIGIN=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
