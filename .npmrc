# pnpm settings for NestJS / TypeORM compatibility.
# node-linker=hoisted creates a flat node_modules tree identical to npm's layout.
# Required because NestJS decorator resolution, TypeORM entity scanning (glob
# patterns), and reflect-metadata wiring all assume packages are reachable from
# root node_modules — the default pnpm symlinked layout breaks them.
node-linker=hoisted
shamefully-hoist=false
strict-peer-dependencies=false
auto-install-peers=true
